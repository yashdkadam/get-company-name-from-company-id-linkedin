{
  "title": "LinkedIn Company Name Extractor",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "startCompanyId": {
      "title": "Start company ID",
      "type": "integer",
      "minimum": 1,
      "default": 1,
      "description": "First numeric f_C value to test."
    },
    "endCompanyId": {
      "title": "End company ID",
      "type": "integer",
      "minimum": 1,
      "default": 100,
      "description": "Last numeric f_C value to test."
    },
    "geoId": {
      "title": "geoId",
      "type": "integer",
      "default": 102713980,
      "description": "LinkedIn geoId value."
    },
    "fTPR": {
      "title": "f_TPR",
      "type": "string",
      "default": "r604800",
      "description": "Time filter. Example: r86400 or r604800."
    },
    "keywords": {
      "title": "Keywords",
      "type": "string",
      "default": "",
      "description": "Optional LinkedIn keywords query."
    },
    "location": {
      "title": "Location",
      "type": "string",
      "default": "India",
      "description": "Optional LinkedIn location string."
    },
    "maxConcurrency": {
      "title": "Max concurrency",
      "type": "integer",
      "default": 1,
      "minimum": 1,
      "maximum": 5,
      "description": "Keep this low for LinkedIn."
    },
    "requestTimeoutSecs": {
      "title": "Request timeout (seconds)",
      "type": "integer",
      "default": 60,
      "minimum": 10,
      "maximum": 300
    }
  },
  "required": ["startCompanyId", "endCompanyId"]
}
